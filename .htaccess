<IfModule mod_rewrite.c>
    RewriteEngine On

    # 🚀 FIX: If the requested path points to a real file or directory that exists, STOP rewriting here!
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 1. If the request is already pointing inside the public directory, do not loop it
    RewriteCond %{REQUEST_URI} !^/public/ [NC]
    RewriteCond %{REQUEST_URI} !^/backend-project-ojt/public/ [NC]

    # 2. Silently catch everything else and feed it to the public subdirectory
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>