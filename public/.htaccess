# 🟢 1. INJECT CORS HEADERS FOR ALL REQUESTS (INCLUDING STATIC JSON FILES)
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "http://localhost:5173"
    Header set Access-Control-Allow-Methods "GET, POST, OPTIONS, PUT, DELETE"
    Header set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
</IfModule>

# 2. RUN YOUR MVC ROUTING RULES
<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the requested path is a real file or folder, load it directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Otherwise, pass the endpoint to index.php cleanly
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>